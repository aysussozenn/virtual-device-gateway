{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gateway/icd.schema.json",
  "title": "ICD",
  "description": "Interface Control Document for one participant. type/widget are open strings so plugins can extend them (see EXTENDING.md).",
  "type": "object",
  "required": ["device", "messages"],
  "additionalProperties": false,
  "properties": {
    "device": { "type": "string", "description": "Participant id this ICD describes." },
    "magic": { "type": "string", "description": "Framing magic word, e.g. \"0xAA55\"." },
    "endianness": { "type": "string", "enum": ["big", "little"], "default": "big" },
    "checksum": { "type": "string", "enum": ["crc16-ccitt", "crc16", "none"], "default": "crc16-ccitt" },
    "framing": { "type": "string", "default": "v1", "description": "Wire framing name resolved by the CodecRegistry." },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/message" }
    }
  },
  "$defs": {
    "message": {
      "type": "object",
      "required": ["name", "command", "direction", "fields"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "command": { "type": "string", "description": "16-bit command id, decimal or \"0x\"-hex." },
        "direction": {
          "type": "string",
          "enum": ["inbound", "outbound"],
          "description": "Relative to the DUT: inbound = DUT receives (peer sends), outbound = DUT sends (peer receives)."
        },
        "port": { "$ref": "#/$defs/port" },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "port": {
      "type": "object",
      "additionalProperties": false,
      "description": "ARINC 653 port attributes.",
      "properties": {
        "kind": { "type": "string", "enum": ["none", "sampling", "queuing"] },
        "dir": { "type": "string", "enum": ["inbound", "outbound"] },
        "refreshMs": { "type": "integer", "minimum": 0, "description": "Sampling: max age before data is stale." },
        "depth": { "type": "integer", "minimum": 0, "description": "Queuing: max queued messages." },
        "maxSize": { "type": "integer", "minimum": 0 }
      }
    },
    "field": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "description": "Wire type name (built-ins: u8 i8 u16 i16 u32 i32 f32; plus any registered IFieldType, e.g. q8_8)." },
        "unit": { "type": "string" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "enum": {
          "type": "object",
          "description": "Coded values: integer-string key -> label.",
          "additionalProperties": { "type": "string" }
        },
        "widget": { "type": "string", "description": "GUI editor hint -> editor.<widget> template. Omit to derive from type." }
      }
    }
  }
}
