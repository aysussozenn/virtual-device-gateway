<Window x:Class="Gateway.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gateway.App"
        xmlns:vm="clr-namespace:Gateway.App.ViewModels"
        mc:Ignorable="d"
        Title="Virtual Device Gateway" Height="720" Width="1180"
        FontFamily="Segoe UI" Background="{StaticResource Bg}" Foreground="{StaticResource Text}">

    <Window.Resources>

        <!-- Catalog chip: click to toggle a message into the workspace -->
        <DataTemplate x:Key="CatalogChip">
            <ToggleButton IsChecked="{Binding IsOpen, Mode=TwoWay}">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" CornerRadius="6" Padding="8,5" Margin="0,2"
                                Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CommandText}" Margin="6,0,0,0" FontSize="11"
                                           Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>
        </DataTemplate>

        <!-- Catalog ListBox item: no selection chrome (the chip carries all visual state) -->
        <Style x:Key="CatalogItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Workspace card: editable OUTGOING message (chosen by type) -->
        <DataTemplate DataType="{x:Type vm:OutgoingMessageVm}">
            <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="10">
                <StackPanel>
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                            <Border Style="{StaticResource Badge}" Margin="8,0,0,0">
                                <TextBlock Text="{Binding CommandText}" Style="{StaticResource MutedText}"/>
                            </Border>
                            <TextBlock Text="{Binding PortText}" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <CheckBox Content="Stream" VerticalAlignment="Center"
                                      IsChecked="{Binding IsStreaming}"
                                      Visibility="{Binding IsSampling, Converter={StaticResource BoolVis}}"/>
                            <Button Content="Send ▸" Command="{Binding SendCommand}"
                                    Visibility="{Binding IsAperiodic, Converter={StaticResource BoolVis}}"/>
                            <Button Content="✕" Style="{StaticResource Ghost}" Margin="8,0,0,0" ToolTip="Close"
                                    Command="{Binding DataContext.CloseCardCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Fields}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                    <!-- Editor chosen by the field's widget hint (pluggable) -->
                                    <ContentControl Grid.Column="1" Content="{Binding}"
                                                    ContentTemplateSelector="{StaticResource FieldEditor}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="{StaticResource SurfaceAlt}" CornerRadius="4" Padding="6" Margin="0,8,0,0">
                        <ItemsControl ItemsSource="{Binding WireHex}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Text}" FontFamily="Consolas" FontSize="12" Margin="2,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Changed}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Workspace card: INCOMING monitor (chosen by type) -->
        <DataTemplate DataType="{x:Type vm:IncomingMessageVm}">
            <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="10">
                <StackPanel>
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource Muted}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasData}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource Success}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStale}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                            <Border Style="{StaticResource Badge}" Margin="8,0,0,0">
                                <TextBlock Text="{Binding CommandText}" Style="{StaticResource MutedText}"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock VerticalAlignment="Center" Text="{Binding LastSeq, StringFormat=seq {0}}" Style="{StaticResource MutedText}"/>
                            <Button Content="✕" Style="{StaticResource Ghost}" Margin="8,0,0,0" ToolTip="Close"
                                    Command="{Binding DataContext.CloseCardCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Fields}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource Muted}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontFamily="Consolas" FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <DockPanel Margin="16">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔌" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Virtual Device Gateway" Style="{StaticResource Title}" VerticalAlignment="Center"/>
                <Border Style="{StaticResource Badge}" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="interactive peer emulation · raw Ethernet" Style="{StaticResource MutedText}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Style="{StaticResource Card}" Padding="12,8" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource Danger}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PeerConsole.IsRunning}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource Success}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding PeerConsole.PcStatus}" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
            </StackPanel>
        </Border>

        <!-- Main: Peer Console (primary) + Verify (secondary) -->
        <TabControl>

            <TabItem Header="Peer Console">
                <Border Style="{StaticResource Card}" Margin="0,8,0,0" Padding="8">
                    <DockPanel>
                        <!-- Session toolbar -->
                        <WrapPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Topology" Width="70" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                            <TextBox Width="300" Text="{Binding PeerConsole.SystemPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Browse…" Style="{StaticResource Ghost}" Margin="6,0,0,0" Command="{Binding PeerConsole.BrowseCommand}"/>
                            <Button Content="Load" Style="{StaticResource Ghost}" Margin="6,0,0,0" Command="{Binding PeerConsole.LoadCommand}"/>
                            <CheckBox Content="Demo mode" Margin="16,0,0,0" VerticalAlignment="Center"
                                      IsChecked="{Binding PeerConsole.DemoMode}"
                                      IsEnabled="{Binding PeerConsole.IsRunning, Converter={StaticResource Not}}"
                                      ToolTip="In-memory bus + echo DUT stand-in (no adapter needed)"/>
                            <ComboBox Width="170" Margin="8,0,0,0" ItemsSource="{Binding PeerConsole.Adapters}" DisplayMemberPath="Display"
                                      SelectedItem="{Binding PeerConsole.SelectedAdapter}"
                                      IsEnabled="{Binding PeerConsole.DemoMode, Converter={StaticResource Not}}"/>
                            <Button Content="⟳" Style="{StaticResource Ghost}" Margin="6,0,0,0" ToolTip="Refresh adapters" Command="{Binding RefreshAdaptersCommand}"/>
                            <Button Content="▶  Start" Margin="12,0,0,0" Command="{Binding PeerConsole.StartCommand}"/>
                            <Button Content="■  Stop" Style="{StaticResource Ghost}" Margin="8,0,0,0" Command="{Binding PeerConsole.StopCommand}"/>
                        </WrapPanel>

                        <!-- 3-pane catalog: peers | message catalog | workspace -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Pane 1: peers -->
                            <DockPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock DockPanel.Dock="Top" Text="PEERS" Style="{StaticResource Section}"/>
                                <ListBox ItemsSource="{Binding PeerConsole.Peers}" SelectedItem="{Binding PeerConsole.SelectedPeer}"
                                         BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="{Binding Id}" FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="{Binding Ip}" Style="{StaticResource MutedText}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <!-- Pane 2: message catalog (click a chip to open it) -->
                            <DockPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock DockPanel.Dock="Top" Text="MESSAGES" Style="{StaticResource Section}"/>
                                <ListBox ItemsSource="{Binding PeerConsole.SelectedPeer.Catalog}"
                                         ItemTemplate="{StaticResource CatalogChip}"
                                         ItemContainerStyle="{StaticResource CatalogItemStyle}"
                                         BorderThickness="0" Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource Section}" Margin="0,8,0,2"/>
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ListBox.GroupStyle>
                                </ListBox>
                            </DockPanel>

                            <!-- Pane 3: workspace (opened messages as full cards) -->
                            <DockPanel Grid.Column="2">
                                <TextBlock DockPanel.Dock="Top" Text="WORKSPACE" Style="{StaticResource Section}"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl DataContext="{Binding PeerConsole.SelectedPeer}"
                                                  ItemsSource="{Binding Workspace}"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>
            </TabItem>

            <TabItem Header="Verify">
                <Border Style="{StaticResource Card}" Margin="0,8,0,0" Padding="8">
                    <DockPanel>

                        <!-- ICD + scenario pickers -->
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Text="ICD topology" Width="84" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                <TextBox Width="360" Text="{Binding Conformance.SystemPath, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Content="Browse…" Style="{StaticResource Ghost}" Margin="6,0,0,0" Command="{Binding Conformance.BrowseCommand}"/>
                                <Button Content="Load" Style="{StaticResource Ghost}" Margin="6,0,0,0" Command="{Binding Conformance.LoadCommand}"/>
                                <Border Style="{StaticResource Badge}" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Conformance.Dut, StringFormat=DUT: {0}}" Style="{StaticResource MutedText}"/>
                                </Border>
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="Scenario" Width="84" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                <TextBox Width="360" Text="{Binding Conformance.ScenarioPath, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Content="Browse…" Style="{StaticResource Ghost}" Margin="6,0,0,0" Command="{Binding Conformance.BrowseScenarioCommand}"/>
                                <Button Content="✓ Run verify" Margin="12,0,0,0" Command="{Binding Conformance.RunCommand}"/>
                                <TextBlock Text="{Binding Conformance.Summary}" VerticalAlignment="Center" Margin="14,0,0,0"
                                           FontWeight="SemiBold" FontFamily="Consolas"/>
                            </WrapPanel>
                        </StackPanel>

                        <TextBlock DockPanel.Dock="Bottom" Margin="2,8,0,0" TextWrapping="Wrap"
                                   Text="{Binding Conformance.ConfStatus}" Foreground="{StaticResource Muted}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock DockPanel.Dock="Top" Text="EMULATED PEERS / ICDs" Style="{StaticResource Section}"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Conformance.Peers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Card}" Margin="0,0,0,6" Padding="8">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Id}" FontWeight="SemiBold" FontSize="13"/>
                                                            <TextBlock Text="{Binding IcdFile}" Style="{StaticResource MutedText}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <ItemsControl ItemsSource="{Binding Messages}" Margin="0,4,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                                                               TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,1"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>

                            <DockPanel Grid.Column="1">
                                <TextBlock DockPanel.Dock="Top" Text="VERDICTS" Style="{StaticResource Section}"/>
                                <DataGrid ItemsSource="{Binding Conformance.Verdicts}" FontSize="12" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Result" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Severity}" FontWeight="SemiBold" Margin="4,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Violation">
                                                                        <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Rule"    Binding="{Binding Rule}"        Width="Auto" FontFamily="Consolas"/>
                                        <DataGridTextColumn Header="t (ms)"  Binding="{Binding TimestampMs}" Width="Auto"/>
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}"     Width="*"/>
                                        <DataGridTextColumn Header="Detail"  Binding="{Binding Detail}"      Width="2*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
