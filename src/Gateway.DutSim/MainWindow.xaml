<Window x:Class="Gateway.DutSim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Gateway.DutSim.ViewModels"
        Title="DUT Simulator — App B (Ethernet peer)" Height="720" Width="1040"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <!-- Card for the currently selected DUT → peer message: editable fields + Send + hex. -->
        <DataTemplate DataType="{x:Type vm:SendMessageVm}">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Fields}" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <Run Text="{Binding TypeText, Mode=OneWay}" Foreground="Gray"/>
                                </TextBlock>
                                <TextBox Grid.Column="1" FontFamily="Consolas"
                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center"
                                           Foreground="Gray" TextTrimming="CharacterEllipsis"
                                           Text="{Binding EnumHint, Mode=OneWay}"
                                           Visibility="{Binding HasHint, Converter={StaticResource BoolVis}}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <DockPanel Margin="0,8,0,0">
                    <Button DockPanel.Dock="Left" Content="Send frame ▶" Padding="14,5"
                            Command="{Binding SendCommand}"/>
                    <ToggleButton DockPanel.Dock="Left" Margin="8,0,0,0" Padding="12,5"
                                  Content="Stream ⟳" IsChecked="{Binding IsStreaming}"
                                  Visibility="{Binding IsSampling, Converter={StaticResource BoolVis}}"
                                  ToolTip="Periodically push this message every refreshMs"/>
                    <TextBlock DockPanel.Dock="Left" Margin="10,0,0,0" VerticalAlignment="Center"
                               Foreground="#777" FontSize="11" Text="{Binding PortText, Mode=OneWay}"/>
                    <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#555"
                               FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis"
                               Text="{Binding HexPreview, Mode=OneWay}"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <!-- One peer → DUT monitor row. -->
        <DataTemplate DataType="{x:Type vm:MonitorMessageVm}">
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,3">
                <StackPanel>
                    <TextBlock>
                        <Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="{Binding CommandText, Mode=OneWay}" Foreground="Gray"/>
                        <Run Text="  seq "/><Run Text="{Binding LastSeq, Mode=OneWay}" FontFamily="Consolas"/>
                        <Run Text="  ×"/><Run Text="{Binding Count, Mode=OneWay}"/>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Fields}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name, Mode=OneWay}" Foreground="#444"/>
                                    <TextBlock Grid.Column="1" FontFamily="Consolas" FontWeight="SemiBold"
                                               Text="{Binding Value}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- One peer tab body. -->
        <DataTemplate DataType="{x:Type vm:PeerPanelVm}">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.ColumnSpan="2" Foreground="#555" Margin="0,0,0,8">
                    <Run Text="peer "/><Run Text="{Binding Id, Mode=OneWay}" FontWeight="SemiBold"/>
                    <Run Text="  "/><Run Text="{Binding Ip, Mode=OneWay}" FontFamily="Consolas"/>
                    <Run Text="  "/><Run Text="{Binding Mac, Mode=OneWay}" FontFamily="Consolas"/>
                </TextBlock>

                <GroupBox Grid.Row="1" Grid.Column="0" Header="Send  (DUT → peer)" Margin="0,20,6,0">
                    <StackPanel Margin="8">
                        <ComboBox ItemsSource="{Binding Sends}" SelectedItem="{Binding SelectedSend}"/>
                        <ContentControl Content="{Binding SelectedSend}" Margin="0,6,0,0"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="1" Grid.Column="1" Header="Received  (peer → DUT)" Margin="6,20,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
                        <ItemsControl ItemsSource="{Binding Monitors}"/>
                    </ScrollViewer>
                </GroupBox>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#F3F4F6" Padding="10" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Adapter:" VerticalAlignment="Center"/>
                    <ComboBox Width="360" Margin="6,0" ItemsSource="{Binding Adapters}"
                              SelectedItem="{Binding SelectedAdapter}" DisplayMemberPath="Display"/>
                    <Button Content="⟳" Padding="8,2" Command="{Binding RefreshAdaptersCommand}" ToolTip="Refresh adapters"/>
                    <CheckBox Content="Auto-reply (echo DUT)" Margin="18,0,0,0" VerticalAlignment="Center"
                              IsChecked="{Binding AutoReply}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Topology:" VerticalAlignment="Center"/>
                    <TextBox Width="360" Margin="6,0" Text="{Binding SystemPath}" FontFamily="Consolas"/>
                    <Button Content="Browse…" Padding="10,2" Command="{Binding BrowseCommand}"/>
                    <Button Content="Load" Padding="14,2" Margin="6,0,0,0" Command="{Binding LoadCommand}"/>
                    <Button Content="Start ▶" Padding="16,2" Margin="18,0,0,0" Command="{Binding StartCommand}"/>
                    <Button Content="Stop ■" Padding="16,2" Margin="6,0,0,0" Command="{Binding StopCommand}"/>
                </StackPanel>
                <TextBlock Margin="0,8,0,0" Foreground="#333" Text="{Binding DutStatus}"/>
            </StackPanel>
        </Border>

        <!-- Wire log -->
        <GroupBox DockPanel.Dock="Bottom" Header="Wire log (newest first)" Height="190" Margin="8,0,8,8">
            <ListBox ItemsSource="{Binding Log}" FontFamily="Consolas" FontSize="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
        </GroupBox>

        <!-- Peer tabs -->
        <TabControl ItemsSource="{Binding Peers}" Margin="8">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Id}" FontWeight="SemiBold"/>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>
    </DockPanel>
</Window>
